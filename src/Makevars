# em_lca.cpp calls BLAS (dgemv/dgemm) directly. On Windows these symbols
# live in Rblas.dll and must be linked explicitly; macOS/Linux resolve them
# transitively through libR. FLIBS is deliberately omitted: there is no
# Fortran source here, and FLIBS breaks macOS builds without gfortran.
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS)
